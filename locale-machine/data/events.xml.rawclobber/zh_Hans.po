#: src-ru/data/events.xml.rawclobber:58316
msgid ""
"data/events.xml.rawclobber$//event[@name=\"BLACK_ZOLTAN_3\"]/choice[1]/event/choice[2]/event/choice/event/choice/event/choice[2]/event/choice/event/text"
msgstr "“摩根，你简直是个不可救药的笨蛋，根本不配被称为科学家。况且你现在是个逃犯，所以我要把你和你那些新朋友一起消灭！开火！”"

#: src-ru/data/events.xml.rawclobber:58331
msgid ""
"data/events.xml.rawclobber$//event[@name=\"BLACK_ZOLTAN_3\"]/choice[2]/text"
msgstr ""

#: src-ru/data/events.xml.rawclobber:58333
