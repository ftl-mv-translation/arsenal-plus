#: src-ru/data/events.xml.rawclobber:3869
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_CRYSTAL_TEXT\"]/text[8]"
msgstr ""
"Crystalin sortices his collection of crystals.You do not understand anything"
