#: src-ru/data/events.xml.rawclobber:3870
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_CRYSTAL_TEXT\"]/text[9]"
msgstr ""
"Crystalin locked his compartment with ice armor.This is a clear sign that he"
