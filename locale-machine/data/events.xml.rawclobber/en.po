#: src-ru/data/events.xml.rawclobber:3871
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_CRYSTAL_TEXT\"]/text[10]"
msgstr ""
"Crystalin trains breathing, opening the gateways of his compartment into "
"space.You do not want to join him and leave."

#: src-ru/data/events.xml.rawclobber:3874
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_CRYSTAL_GOOD_TEXT\"]/text"
msgstr ""
"You discover that the Crystal you approached has grown some kind of special "
