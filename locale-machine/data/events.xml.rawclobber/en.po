#: src-ru/data/events.xml.rawclobber:3868
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_CRYSTAL_TEXT\"]/text[7]"
msgstr ""
"Crystalin reads a database about Rock Rock.His interest can be understood, "
