#: src-ru/data/events.xml.rawclobber:3864
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_CRYSTAL_TEXT\"]/text[4]"
msgstr ""
"Crystalin stares at you, and you freeze in surprise.Its crystal surface "
