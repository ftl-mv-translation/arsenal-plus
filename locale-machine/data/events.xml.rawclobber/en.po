#: src-ru/data/events.xml.rawclobber:3865
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_CRYSTAL_TEXT\"]/text[5]"
msgstr ""
"Crystalin communicates quite arrogantly, constantly mentioning the "
