"data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/choice[@req=\"BOARDER_ION\"]/event/text"
msgstr ""
"You launch a drone toward the station. The defense system almost hit it, but"
" your drone manages to slip away and randomly ionize the AI's cores and "
"systems."

#: src-ru/data/events_engi.xml.rawclobber:8431
msgid ""
"data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/choice[@req=\"engi_crew\"]/text"
