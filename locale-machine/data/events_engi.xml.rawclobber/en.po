#: src-ru/data/events_engi.xml.rawclobber:8479
msgid ""
"data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/choice[@req=\"magman\""
" and @lvl=\"1\"]/event/text"
msgstr ""
"You send the Magmen to the station in a small pod. The defense system almost"
" hit them, but they make it to the destination safely."

#: src-ru/data/events_engi.xml.rawclobber:8487
msgid ""
"data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/choice[@req=\"magman\""
" and @lvl=\"2\"]/text"
msgstr "(Magmen crew members) Start a fire on the station to distract the AI."

#: src-ru/data/events_engi.xml.rawclobber:8489
