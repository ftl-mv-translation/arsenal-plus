msgstr ""
"This exhibit is an unusual machine completely made of plant materials.The "
"car pumps juice from slender trees with a white bark and processes it, "
"receiving a liquid advertised as a high-quality ftl fuel at the output."

#: src-ru/data/events_engi.xml.rawclobber:8997
msgid ""
"data/events_engi.xml.rawclobber$//event[@name=\"ORCHID_BOTANICAL_GALLERY_1\"]/choice[3]/event/choice/event/text"
msgstr ""
"Since you have already paid for the entrance, orchids offer a little "
"experimental fuel for free."

#: src-ru/data/events_engi.xml.rawclobber:9006
msgid ""
"data/events_engi.xml.rawclobber$//event[@name=\"ORCHID_BOTANICAL_GALLERY_1\"]/choice[4]/text"
