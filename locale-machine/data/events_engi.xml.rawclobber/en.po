"data/events_engi.xml.rawclobber$//ship[@name=\"ORCHID_JELLY\"]/deadCrew/text"
msgstr ""
"You manage to kill all the Slurms and prevent their regeneration process. "
"Inside the ship, you find a secret storage room containing bundles of "
"Orchids. After freeing them, one Orchid joins your crew."

#: src-ru/data/events_engi.xml.rawclobber:8366
msgid ""
"data/events_engi.xml.rawclobber$//textList[@name=\"MOTILEK_RED_EVENT_TEXT\"]/text[1]"
msgstr ""
