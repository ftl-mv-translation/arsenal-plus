"data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/choice[@req=\"engi_crew\"]/event/text"
msgstr ""
"You send the Engi to the station in a small pod. The defense system almost "
"hit them, but they made it to the destination safely."

#: src-ru/data/events_engi.xml.rawclobber:8442
msgid ""
"data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/choice[@req=\"morph\"]/text"
msgstr ""
"(Morph crew member) Your Morph knows how to interrupt the AI's program."

#: src-ru/data/events_engi.xml.rawclobber:8444
msgid ""
"data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/choice[@req=\"morph\"]/event/text"
msgstr ""
"You send the Morph to the station in a small pod. The defense system almost "
"hit them, but they made it to the destination safely."

#: src-ru/data/events_engi.xml.rawclobber:8448
