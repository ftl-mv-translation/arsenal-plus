#: src-ru/data/events_engi.xml.rawclobber:8415
msgid "data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/text"
msgstr ""
"The beacon is near a newborn star surrounded by dust clouds. An Orchid "
"station is in orbit. Your crew is sure that the distress signal previously "
"detected comes from here. It seems the station's AI seized control and "
"killed the crew."

#: src-ru/data/events_engi.xml.rawclobber:8418
msgid ""
"data/events_engi.xml.rawclobber$//event[@name=\"MAD_ORCHID_STATION\"]/choice[@req=\"BOARDER_ION\"]/text"
