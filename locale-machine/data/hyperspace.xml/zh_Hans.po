#: src-ru/data/hyperspace.xml:931
msgid "data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[3]/tooltip"
msgstr ""
"高级纳米机器人\n"
"\t\t\t此增强效果结合了防御性纳米机器人和恩基人纳米医疗机器人的效果。"

#: src-ru/data/hyperspace.xml:936
msgid "data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[4]/tooltip"
msgstr ""
"佐尔坦科技\n"
"\t\t\t此增强效果结合了佐尔坦护盾和超级护盾穿透效果。"

#: src-ru/data/hyperspace.xml:941
msgid "data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[5]/tooltip"
msgstr ""
"安全系统\n"
"\t\t\t此增强效果结合了史拉格修理胶和灭火系统的效果。"

#: src-ru/data/hyperspace.xml:946
msgid "data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[6]/tooltip"
msgstr ""
"复合装甲\n"
"\t\t\t此增强效果结合了水晶人复仇和岩石人外壳效果。"

#: src-ru/data/hyperspace.xml:951
msgid "data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[7]/tooltip"
msgstr ""
"防护场\n"
"\t\t\t此增强效果结合了钛合金涂层和逆向离子场效果。"

#: src-ru/data/hyperspace.xml:956
msgid "data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[8]/tooltip"
msgstr ""
"导航机制\n"
"\t\t\t此增强效果结合了 FTL 导航仪和无人机回收机制的效果。"

#: src-ru/data/hyperspace.xml:961
msgid "data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[9]/tooltip"
msgstr ""
"FTL控制器\n"
"\t\t\t此增强装置结合了FTL超速驱动器和FTL干扰器的效果。"

#: src-ru/data/hyperspace.xml:966
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[10]/tooltip"
msgstr ""
"装填补偿器\n"
"\t\t\t此增强装置结合了武器预热器和自动装填器的效果。"

#: src-ru/data/hyperspace.xml:971
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[11]/tooltip"
msgstr ""
"隐形护盾\n"
"\t\t\t此增强装置结合了护盾充能加速器和隐形武器的效果。"

#: src-ru/data/hyperspace.xml:976
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[12]/tooltip"
msgstr ""
"高级扫描仪\n"
"\t\t\t此增强装置结合了长程扫描仪和红外扫描仪的效果。"

#: src-ru/data/hyperspace.xml:981
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[13]/tooltip"
msgstr ""
"高级机械臂\n"
"\t\t\t此增强装置结合了废料回收臂和维修臂的效果。"

#: src-ru/data/hyperspace.xml:986
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[14]/tooltip"
msgstr ""
"安全保存模块\n"
"\t\t\t此增强装置结合了备用DNA库和安全传送器的效果。"

#: src-ru/data/hyperspace.xml:991
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[15]/tooltip"
msgstr ""
"黑客装备\n"
"\t\t\t此增强装置结合了干扰发生器和瘫痪模块的效果。"

#: src-ru/data/hyperspace.xml:996
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[16]/tooltip"
msgstr ""
"辅助模块\n"
"\t\t\t此增强装置结合了干扰浮标和备用电容器的效果。"

#: src-ru/data/hyperspace.xml:1001
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[17]/tooltip"
msgstr ""
"支持模块\n"
"\t\t\t此增强装置结合了导弹复制器和无人机加速器的效果。"

#: src-ru/data/hyperspace.xml:1006
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[18]/tooltip"
msgstr ""
"医疗物资：\n"
"\t\t\t一个容器，内含用于各种紧急情况下急救的医疗包。"

#: src-ru/data/hyperspace.xml:1011
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[19]/tooltip"
msgstr ""
"脱水食品：\n"
"\t\t\t此容器内的太空口粮足够维持小型船员一个月的生活。"

#: src-ru/data/hyperspace.xml:1016
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[20]/tooltip"
msgstr ""
"通讯设备：\n"
"\t\t\t该容器包含多种发射器和接收器，用于确保超远距离通讯。"

#: src-ru/data/hyperspace.xml:1021
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[21]/tooltip"
msgstr ""
"放射性：\n"
"\t\t\t每当飞船受到伤害时，都会发出辐射脉冲，点燃敌方飞船。对船员也会产生一些无法解释的影响。"

#: src-ru/data/hyperspace.xml:1026
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[22]/tooltip"
msgstr ""
"厌氧火焰：\n"
"\t\t\t敌方飞船上的火灾不会因缺乏氧气而熄灭。目标船体不再因系统燃烧而受损。"

#: src-ru/data/hyperspace.xml:1031
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[23]/tooltip"
msgstr ""
"自动系统维修：\n"
"\t\t\t自动修复受损飞船系统，功能如同无人船。"

#: src-ru/data/hyperspace.xml:1036
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[24]/tooltip"
msgstr ""
"氧气控制器：\n"
"\t\t\t自动从充满敌人或火灾的房间抽出氧气，并注入有友方船员的房间。抽排速度取决于氧气系统分配的能量。对厌氧种族无效。"

#: src-ru/data/hyperspace.xml:1041
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[25]/tooltip"
msgstr ""
"维修纳米机器人：\n"
"\t\t\t系统维修速度提高50%。"

#: src-ru/data/hyperspace.xml:1046
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[26]/tooltip"
msgstr ""
"抗维修机器人：\n"
"\t\t\t敌方系统维修速度降低50%。"

#: src-ru/data/hyperspace.xml:1051
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[27]/tooltip"
msgstr ""
"量子模拟器：\n"
"\t\t\t从飞船传送人员时，每名传送的船员有50%几率创建一个临时复制体。"

#: src-ru/data/hyperspace.xml:1056
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[28]/tooltip"
msgstr ""
"火炮自动瞄准器：\n"
"\t\t\t增加所有火炮的命中率 (+100)。"

#: src-ru/data/hyperspace.xml:1062
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[29]/tooltip"
msgstr ""
"显影场：\n"
"\t\t\t强制解除敌方飞船的隐形状态。"

#: src-ru/data/hyperspace.xml:1067
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[30]/tooltip"
msgstr ""
"导弹复制器：\n"
"\t\t\t使用导弹的武器有75%的几率不消耗弹药。"

#: src-ru/data/hyperspace.xml:1072
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[31]/tooltip"
msgstr ""
"干扰浮标：\n"
"\t\t\t跃迁时可留下伪造信号，以迷惑追兵。"

#: src-ru/data/hyperspace.xml:1077
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[32]/tooltip"
msgstr ""
"红外扫描仪：\n"
"\t\t\t即使传感器失效，也能探测到任何生命形式。"

#: src-ru/data/hyperspace.xml:1082
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[33]/tooltip"
msgstr ""
"废料回收臂：\n"
"\t\t\t从任何来源收集的废料增加15%。"

#: src-ru/data/hyperspace.xml:1087
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[34]/tooltip"
msgstr ""
"长程扫描仪：\n"
"\t\t\t收集星图上邻近信标的额外信息，并显示商店位置。"

#: src-ru/data/hyperspace.xml:1092
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[35]/tooltip"
msgstr ""
"武器预热器：\n"
"\t\t\t战斗开始前武器即完成首次装填。"

#: src-ru/data/hyperspace.xml:1097
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[36]/tooltip"
msgstr ""
"FTL超速驱动器：\n"
"\t\t\t加快FTL驱动器充能。在扇区开始时额外发现一个连接两个遥远信标的超空间隧道。"

#: src-ru/data/hyperspace.xml:1102
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[37]/tooltip"
msgstr ""
"无人机回收装置：\n"
"\t\t\t跃迁时，所有飞行中或登舰的未损毁无人机将被转化为无人机零件。"

#: src-ru/data/hyperspace.xml:1107
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[38]/tooltip"
msgstr ""
"FTL干扰器：\n"
"\t\t\t使敌舰FTL跃迁计算时间加倍。"

#: src-ru/data/hyperspace.xml:1112
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[39]/tooltip"
msgstr ""
"破损的休眠舱：\n"
"\t\t\t一件奇异的外星神器。目前没有实际用途，但也许有人能修理它。"

#: src-ru/data/hyperspace.xml:1117
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[40]/tooltip"
msgstr ""
"维修臂：\n"
"\t\t\t每次收集废料时修复船体，但减少10%的废料收集量。船体满值时不减少收集量。"

#: src-ru/data/hyperspace.xml:1122
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[41]/tooltip"
msgstr ""
"塔利上将的容器：\n"
"\t\t\t该容器已锁。上面写着“致塔利上将”。也许应该把它交给收件人。"

#: src-ru/data/hyperspace.xml:1127
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[42]/tooltip"
msgstr ""
"贸易浮标：\n"
"\t\t\t可以召唤一艘自动贸易船。"

#: src-ru/data/hyperspace.xml:1132
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[43]/tooltip"
msgstr ""
"兰花容器：\n"
"\t\t\t该容器已锁。里面装着各种植物、种子和孢子的生物样本。"

#: src-ru/data/hyperspace.xml:1137
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[44]/tooltip"
msgstr "类固醇：增加全体船员 15 点生命值。"

#: src-ru/data/hyperspace.xml:1142
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[45]/tooltip"
msgstr "类固醇：增加全体船员 25 点生命值。"

#: src-ru/data/hyperspace.xml:1147
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[46]/tooltip"
msgstr ""
"类固醇：\n"
"\t\t\t全员最大生命值增加25。"

#: src-ru/data/hyperspace.xml:1152
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[47]/tooltip"
msgstr "类固醇：增加全体船员 45 点生命值，战斗伤害 +10%。"

#: src-ru/data/hyperspace.xml:1157
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[48]/tooltip"
msgstr ""
"类固醇：\n"
"\t\t\t全员最大生命值增加45，战斗伤害增加10%。"

#: src-ru/data/hyperspace.xml:1162
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[49]/tooltip"
msgstr "装甲服：全体船员受到的伤害降低 10%。移动速度降低 15%。"

#: src-ru/data/hyperspace.xml:1167
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[50]/tooltip"
msgstr "装甲服：全体船员受到的伤害降低 15%。移动速度降低 15%。"

#: src-ru/data/hyperspace.xml:1172
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[51]/tooltip"
msgstr ""
"装甲服：\n"
"\t\t\t全员所受伤害降低15%。移动速度降低15%。"

#: src-ru/data/hyperspace.xml:1177
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[52]/tooltip"
msgstr ""
"装甲服：\n"
"\t\t\t全员所受伤害降低20%。"

#: src-ru/data/hyperspace.xml:1182
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[53]/tooltip"
msgstr ""
"装甲服：\n"
"\t\t\t全员所受伤害降低25%。移动速度提高15%。获得免疫火焰效果。"

#: src-ru/data/hyperspace.xml:1187
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[54]/tooltip"
msgstr ""
"菌丝体：\n"
"\t\t\t船员移动速度提高25%，每次跃迁后修复1点船体。船体满值时可能会产出幼年蘑菇。此增强装置不可卸载。"

#: src-ru/data/hyperspace.xml:1192
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[55]/tooltip"
msgstr ""
"无人机回收装置：\n"
"\t\t\t跃迁时，所有登舰的未损毁无人机将被转化为无人机零件。"

#: src-ru/data/hyperspace.xml:1197
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[56]/tooltip"
msgstr ""
"神经操纵器：\n"
"\t\t\t友方获得精神控制免疫，并完全控制被精神控制的敌人。敌人的所有技能变为友方技能。需飞船配备已供能的精神控制系统。"

#: src-ru/data/hyperspace.xml:1202
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[57]/tooltip"
msgstr ""
"FTL导航仪：\n"
"\t\t\t允许飞船跃迁至任何信标，但需消耗额外燃油。"

#: src-ru/data/hyperspace.xml:1207
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[58]/tooltip"
msgstr ""
"防御纳米机器人：\n"
"\t\t\t持续攻击入侵本船的敌方登舰人员。"

#: src-ru/data/hyperspace.xml:1212
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[59]/tooltip"
msgstr ""
"腐蚀性气体：\n"
"\t\t\t有害气体对船上外人造成伤害。己方船员完全免疫该气体。"

#: src-ru/data/hyperspace.xml:1217
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[60]/tooltip"
msgstr ""
"变形稳定器：\n"
"\t\t\t允许控制处于短路状态的变形怪。使短路持续时间延长三倍。"

#: src-ru/data/hyperspace.xml:1222
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[61]/tooltip"
msgstr ""
"便携传送器：\n"
"\t\t\t船员现在可以通过便携传送器在飞船内部移动。"

#: src-ru/data/hyperspace.xml:1228
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[62]/tooltip"
msgstr ""
"自动装填器：\n"
"\t\t\t武器和火炮的射击间隔减少25%。"

#: src-ru/data/hyperspace.xml:1233
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[63]/tooltip"
msgstr ""
"斯拉格维修凝胶：\n"
"\t\t\t一种能自动修补船体漏洞的浓稠凝胶。"

#: src-ru/data/hyperspace.xml:1238
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[64]/tooltip"
msgstr ""
"隐形武器：\n"
"\t\t\t允许在隐形状态下射击而不解除隐形。"

#: src-ru/data/hyperspace.xml:1243
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[65]/tooltip"
msgstr ""
"钛合金涂层：\n"
"\t\t\t所有飞船系统获得33%几率免疫受到的伤害。"

#: src-ru/data/hyperspace.xml:1248
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[66]/tooltip"
msgstr ""
"黑翼：\n"
"\t\t\t武器室免疫武器伤害和离子化。"

#: src-ru/data/hyperspace.xml:1253
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[67]/tooltip"
msgstr ""
"佐尔坦护盾：\n"
"\t\t\t护盾室免疫武器伤害和离子化。"

#: src-ru/data/hyperspace.xml:1258
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[68]/tooltip"
msgstr ""
"岩石人船体装甲：\n"
"\t\t\t改进型装甲，有33%几率使受到的船体伤害降为零。"

#: src-ru/data/hyperspace.xml:1263
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[69]/tooltip"
msgstr ""
"自动灭火系统：\n"
"\t\t\t自动扑灭飞船上的火灾。"

#: src-ru/data/hyperspace.xml:1268
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[70]/tooltip"
msgstr ""
"螳螂费洛蒙：\n"
"\t\t\t船员移动速度大幅提升。"

#: src-ru/data/hyperspace.xml:1273
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[71]/tooltip"
msgstr ""
"氧气面罩：\n"
"\t\t\t船员几乎不会受到窒息伤害。"

#: src-ru/data/hyperspace.xml:1278
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[72]/tooltip"
msgstr ""
"超级护盾穿透：\n"
"\t\t\t允许传送、炸弹和精神控制效果穿透超级护盾。"

#: src-ru/data/hyperspace.xml:1283
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[73]/tooltip"
msgstr ""
"护盾充能加速器：\n"
"\t\t\t护盾回复速度提高50%。"

#: src-ru/data/hyperspace.xml:1288
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[74]/tooltip"
msgstr ""
"英吉纳米医疗机器人：\n"
"\t\t\t即使在医疗室外也能治疗飞船上的船员。"

#: src-ru/data/hyperspace.xml:1293
msgid ""
"data/hyperspace.xml$/dummyroot/FTL/ships/shipIcons/shipIcon[75]/tooltip"
msgstr ""
"佐尔坦护盾：\n"
