#: src-ru/data/dlcEvents_anaerobic.xml.rawclobber:941
msgid ""
"data/dlcEvents_anaerobic.xml.rawclobber$//textList[@name=\"LANIUS_FIGHT_TEXT\"]/text[1]"
msgstr "传感器注意到一艘小型食铁族巡洋舰正在拆解另一艘小型食铁族飞船。你还没来得及惊讶是什么让他们反目成仇，那艘巡洋舰就发现了你，并发起了攻击。"

#: src-ru/data/dlcEvents_anaerobic.xml.rawclobber:942
msgid ""
"data/dlcEvents_anaerobic.xml.rawclobber$//textList[@name=\"LANIUS_FIGHT_TEXT\"]/text[2]"
msgstr ""
