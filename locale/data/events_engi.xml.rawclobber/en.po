#: src-ru/data/events_engi.xml.rawclobber:397
msgid ""
"data/events_engi.xml.rawclobber$//eventList[@name=\"SAVE_ENGI_STATION\"]/event[3]/choice[@req=\"engi_crew\"]/event/text"
msgstr ""
"They respond, \"Understood. Re-establishment of Federation highest import. "
"Transmitting hidden base coordinates. Repairing hull and attaching ship to "
"ship ordnance.\""

#: src-ru/data/events_engi.xml.rawclobber:406
msgid ""
"data/events_engi.xml.rawclobber$//eventList[@name=\"SAVE_ENGI_STATION\"]/event[4]/text"
msgstr ""
"They thank you for the assistance and when you tell them of your mission, "
