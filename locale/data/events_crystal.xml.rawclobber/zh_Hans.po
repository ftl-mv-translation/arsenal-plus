"data/events_crystal.xml.rawclobber$//event[@name=\"CRYSTAL_HUMAN_TESTS\"]/choice[@req=\"BACKUP_DNA\"]/text"
msgstr "（备份基因库）发送你的船员数据。"

#: src-ru/data/events_crystal.xml.rawclobber:602
