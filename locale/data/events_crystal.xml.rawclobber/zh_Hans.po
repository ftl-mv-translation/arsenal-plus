#: src-ru/data/events_crystal.xml.rawclobber:885
msgid ""
"data/events_crystal.xml.rawclobber$//textList[@name=\"CRYSTAL_SHIP_SURRENDER\"]/text[9]"
msgstr "他们告诉你：“现在我明白之前存在误解，没必要再流血了。你们能原谅我们的轻率吗？”"

#: src-ru/data/events_crystal.xml.rawclobber:886
msgid ""
"data/events_crystal.xml.rawclobber$//textList[@name=\"CRYSTAL_SHIP_SURRENDER\"]/text[10]"
msgstr "“我们打不过你们，我们投降。当然，无论你们来自哪里，那里应该都有同情心。”"

#: src-ru/data/events_crystal.xml.rawclobber:899
msgid ""
"data/events_crystal.xml.rawclobber$//eventList[@name=\"CRYSTAL_SHIP_SURRENDER\"]/event[3]/text"
msgstr "一个看起来像年轻士兵的人挤到通讯器前：“一个既在战斗中强大又宽容的舰长？我一直想探索我们封闭星区之外的世界……请允许我加入你的船员队伍。”"

#: src-ru/data/events_crystal.xml.rawclobber:902
msgid ""
"data/events_crystal.xml.rawclobber$//eventList[@name=\"CRYSTAL_SHIP_SURRENDER\"]/event[3]/choice[1]/text"
