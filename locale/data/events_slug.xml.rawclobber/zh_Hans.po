#: src-ru/data/events_slug.xml.rawclobber:1271
msgid ""
"data/events_slug.xml.rawclobber$//event[@name=\"NEBULA_QUEST_SLUG_PIRATE_TRAP\"]/choice[2]/text"
msgstr "飞过去。"

#: src-ru/data/events_slug.xml.rawclobber:1273
msgid ""
"data/events_slug.xml.rawclobber$//event[@name=\"NEBULA_QUEST_SLUG_PIRATE_TRAP\"]/choice[2]/event/text"
