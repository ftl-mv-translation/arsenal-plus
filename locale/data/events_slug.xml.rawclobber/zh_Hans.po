"开火了。阴谋不成，就来硬的……"

#: src-ru/data/events_slug.xml.rawclobber:1260
msgid ""
"data/events_slug.xml.rawclobber$//event[@name=\"NEBULA_QUEST_SLUG_PIRATE_TRAP\"]/text"
msgstr "你进入了与两艘蛞蝓族飞船的通讯距离内。他们还没有发现你。"

#: src-ru/data/events_slug.xml.rawclobber:1264
msgid ""
"data/events_slug.xml.rawclobber$//event[@name=\"NEBULA_QUEST_SLUG_PIRATE_TRAP\"]/choice[1]/text"
