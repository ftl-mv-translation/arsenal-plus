#: src-ru/data/events.xml.rawclobber:3124
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_ENERGY_TEXT\"]/text[2]"
msgstr "你走向佐尔坦，但他的光环刺痛了你的眼睛。你把谈话推迟到以后。"

#: src-ru/data/events.xml.rawclobber:3126
msgid ""
"data/events.xml.rawclobber$//textList[@name=\"NOTHING2_ENERGY_TEXT\"]/text[3]"
msgstr "佐尔坦告诉你一些关于自己解剖学的细节。你宁愿不知道这些。"

#: src-ru/data/events.xml.rawclobber:3127
