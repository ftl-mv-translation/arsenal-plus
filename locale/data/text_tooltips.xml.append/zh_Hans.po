#: src-ru/data/text_tooltips.xml.append:6
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_oxygen\"]"
msgstr "氧气：补充飞船的氧气供应。"

#: src-ru/data/text_tooltips.xml.append:7
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_doors\"]"
msgstr "门禁系统：允许远程开关门。"

#: src-ru/data/text_tooltips.xml.append:8
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_doors_touch\"]"
msgstr ""
"门禁系统：允许远程开关门。点击你飞船上的任意门，或滑动选择多扇门，即可打开或"
"关闭它们。"

#: src-ru/data/text_tooltips.xml.append:9
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_shields\"]"
msgstr "护盾：生成阻挡射弹的防护屏障。安排船员操控可提高护盾恢复速度。"

#: src-ru/data/text_tooltips.xml.append:10
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_pilot\"]"
msgstr "驾驶系统：需要船员驾驶才能在战斗中执行规避机动或进行跃迁。"

#: src-ru/data/text_tooltips.xml.append:11
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_engines\"]"
msgstr "引擎：为超光速驱动器和机动引擎充能。安排船员操控可提高闪避几率。"

#: src-ru/data/text_tooltips.xml.append:12
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_sensors\"]"
msgstr "传感器：允许你查看所有舱室，并提供敌方飞船的信息。"

#: src-ru/data/text_tooltips.xml.append:13
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_medbay\"]"
msgstr "医疗舱：治疗舱内的船员。"

#: src-ru/data/text_tooltips.xml.append:14
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_weapons\"]"
msgstr "武器：点击武器图标即可为其充能并开火。安排船员操控可加快装填速度。"

#: src-ru/data/text_tooltips.xml.append:15
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_weapons_touch\"]"
msgstr "武器：点击武器图标即可为其充能并开火。安排船员操控可加快装填速度。"

#: src-ru/data/text_tooltips.xml.append:16
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_drones\"]"
msgstr "无人机：为攻击和防御用的自动机器人提供电力。"

#: src-ru/data/text_tooltips.xml.append:17
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_teleporter\"]"
msgstr "传送器：将传送舱内的船员送至敌方飞船进行登舰作战。"

#: src-ru/data/text_tooltips.xml.append:18
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_cloaking\"]"
msgstr ""
"隐形：将飞船部分隐藏到另一个维度，增加 +60 闪避。暂时阻止敌方武器的充能和瞄准"
"。"

#: src-ru/data/text_tooltips.xml.append:19
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_artillery\"]"
msgstr "巨炮：光束自动穿透所有护盾，造成 1 点伤害。"

#: src-ru/data/text_tooltips.xml.append:20
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_powerTotal\"]"
msgstr "反应堆：未使用的能量，可用于为系统供电。"

#: src-ru/data/text_tooltips.xml.append:21
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_battery\"]"
msgstr "备用电池：激活后可临时增加反应堆产生的能量。"

#: src-ru/data/text_tooltips.xml.append:22
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_clonebay\"]"
msgstr "克隆舱：自动克隆已死亡的船员。"

#: src-ru/data/text_tooltips.xml.append:23
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_mind\"]"
msgstr "心灵控制：暂时将指定舱室内的敌人转变为盟友。"

#: src-ru/data/text_tooltips.xml.append:24
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_hacking\"]"
msgstr "黑客：锁定带有系统的舱室，并周期性地干扰该系统，击晕其中的船员。"

#: src-ru/data/text_tooltips.xml.append:27
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_oxygen_enemy\"]"
msgstr "氧气系统：补充敌方飞船上的氧气水平。"

#: src-ru/data/text_tooltips.xml.append:28
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_doors_enemy\"]"
msgstr "门禁系统：控制敌方飞船的门禁系统，用于阻碍你的登舰队伍移动。"

#: src-ru/data/text_tooltips.xml.append:29
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_shields_enemy\"]"
msgstr "护盾：生成敌方的防护屏障。"

#: src-ru/data/text_tooltips.xml.append:30
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_pilot_enemy\"]"
msgstr "驾驶系统：有船员操控时，可使敌方飞船闪避你的攻击。"

#: src-ru/data/text_tooltips.xml.append:31
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_engines_enemy\"]"
msgstr "引擎：为敌方飞船的超光速驱动器和机动引擎充能。"

#: src-ru/data/text_tooltips.xml.append:32
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_sensors_enemy\"]"
msgstr "传感器：对敌人无用。"

#: src-ru/data/text_tooltips.xml.append:33
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_medbay_enemy\"]"
msgstr "医疗舱：治疗敌方船员。"

#: src-ru/data/text_tooltips.xml.append:34
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_weapons_enemy\"]"
msgstr "武器：为敌方武器供电。"

#: src-ru/data/text_tooltips.xml.append:35
msgid ""
"data/text_tooltips.xml.append$//text[@name=\"tooltip_weapons_touch_enemy\"]"
msgstr "武器：为敌方武器供电——摧毁它即可使其停止射击。"

#: src-ru/data/text_tooltips.xml.append:36
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_drones_enemy\"]"
msgstr "无人机：为敌方无人机供电——摧毁它即可使其失效。"

#: src-ru/data/text_tooltips.xml.append:37
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_teleporter_enemy\"]"
msgstr "传送器：敌人用它来传送登舰者到你的飞船上。"

#: src-ru/data/text_tooltips.xml.append:38
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_cloaking_enemy\"]"
msgstr "隐形：使用时，你的武器无法充能，敌方飞船的闪避率增加 60。"

#: src-ru/data/text_tooltips.xml.append:39
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_artillery_enemy\"]"
msgstr "巨炮：为一门强大的武器供电。"

#: src-ru/data/text_tooltips.xml.append:40
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_battery_enemy\"]"
msgstr "备用电池：临时增加敌方反应堆的能量。"

#: src-ru/data/text_tooltips.xml.append:41
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_clonebay_enemy\"]"
msgstr "克隆舱：会自动克隆被你杀死的任何敌方船员，使其重返战斗！"

#: src-ru/data/text_tooltips.xml.append:42
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_mind_enemy\"]"
msgstr "心灵控制：允许敌人暂时控制你的队伍——摧毁它可防止这种情况。"

#: src-ru/data/text_tooltips.xml.append:43
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_hacking_enemy\"]"
msgstr "黑客：发射黑客无人机，能够暂时使系统失效。"

#: src-ru/data/text_tooltips.xml.append:46
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_hull\"]"
msgstr "当前船体完整性。若降至零，飞船将被摧毁。"

#: src-ru/data/text_tooltips.xml.append:47
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_droneCount\"]"
msgstr "无人机部件数量。激活无人机时消耗一个部件。"

#: src-ru/data/text_tooltips.xml.append:48
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_fuelCount\"]"
msgstr "燃料数量。每次跃迁消耗 1 单位燃料。"

#: src-ru/data/text_tooltips.xml.append:49
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_missileCount\"]"
msgstr "导弹储备。部分武器每次发射消耗一枚导弹。"

#: src-ru/data/text_tooltips.xml.append:50
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_scrapCount\"]"
msgstr "当前废料数量。"

#: src-ru/data/text_tooltips.xml.append:51
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_FTLButton\"]"
msgstr "打开星图，你可以选择下一次跃迁的方向。"

#: src-ru/data/text_tooltips.xml.append:52
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_jump_noPiloting\"]"
msgstr "跃迁需要你的驾驶系统正常运行。"

#: src-ru/data/text_tooltips.xml.append:53
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_jump_noCrew\"]"
msgstr "跃迁需要驾驶系统中有船员。"

#: src-ru/data/text_tooltips.xml.append:54
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_jump_noEngines\"]"
msgstr "跃迁需要你的引擎正常运行。"

#: src-ru/data/text_tooltips.xml.append:55
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_jump_noFuel\"]"
msgstr "没有燃料无法进行跃迁。"

#: src-ru/data/text_tooltips.xml.append:56
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_shieldDisplay\"]"
msgstr "当前护盾状态。"

#: src-ru/data/text_tooltips.xml.append:57
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_evadeDisplay\"]"
msgstr "闪避率：敌方射弹击中你飞船的几率。由你引擎的功率等级决定。"

#: src-ru/data/text_tooltips.xml.append:58
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_oxygenDisplay\"]"
msgstr ""
"氧气：你飞船的平均氧气水平。大多数船员需要氧气才能生存。你的氧气系统在通电时"
"会补充氧气水平。"

#: src-ru/data/text_tooltips.xml.append:59
msgid ""
"data/text_tooltips.xml.append$//text[@name=\"tooltip_energyShieldDisplay\"]"
msgstr "超能族超级护盾：完全阻挡任何类型武器的来袭伤害。"

#: src-ru/data/text_tooltips.xml.append:62
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_autofire\"]"
msgstr ""
"开启/关闭自动开火模式。快捷键：\\1\\n\\n\\2 + 选择目标 将武器切换到相反的射击"
"模式。"

#: src-ru/data/text_tooltips.xml.append:64
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_asteroids\"]"
msgstr "你处于小行星带中。小行星会周期性地撞击你的飞船。"

#: src-ru/data/text_tooltips.xml.append:65
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_sun\"]"
msgstr "你靠近恒星。恒星表面的耀斑可能会点燃飞船。护盾可降低此几率。"

#: src-ru/data/text_tooltips.xml.append:66
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_nebula\"]"
msgstr "你位于星云内部。星云会阻挡传感器工作，但也会减缓叛军舰队的推进速度。"

#: src-ru/data/text_tooltips.xml.append:67
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_storm\"]"
msgstr "此星云区域正遭受离子风暴。由于干扰，反应堆仅能产生一半能量。"

#: src-ru/data/text_tooltips.xml.append:68
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_pulsar\"]"
msgstr "你靠近脉冲星。电磁波会周期性地禁用附近所有飞船的系统。"

#: src-ru/data/text_tooltips.xml.append:69
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_PDS_FLEET\"]"
msgstr "舰队防空炮正在瞄准你。"

#: src-ru/data/text_tooltips.xml.append:70
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_PDS_PLAYER\"]"
msgstr "行星上的防空炮正在瞄准你。"

#: src-ru/data/text_tooltips.xml.append:71
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_PDS_ENEMY\"]"
msgstr "行星上的防空炮正在瞄准你的敌人。"

#: src-ru/data/text_tooltips.xml.append:72
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_PDS_ALL\"]"
msgstr "行星上的防空炮正在向该区域的所有飞船开火。"

#: src-ru/data/text_tooltips.xml.append:74
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_map_wait\"]"
msgstr "等待救援到达。"

#: src-ru/data/text_tooltips.xml.append:75
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_map_distress\"]"
msgstr "启用求救信标可能会增加你被发现的几率，但不知道谁会先找到你。"

#: src-ru/data/text_tooltips.xml.append:77
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_rename\"]"
msgstr "点击可重命名。"

#: src-ru/data/text_tooltips.xml.append:78
msgid "data/text_tooltips.xml.append$//text[@name=\"tooltip_subsystems\"]"
msgstr "子系统不消耗反应堆能量，只要未受损就会一直工作。"
