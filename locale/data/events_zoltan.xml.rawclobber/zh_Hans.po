"许他们会帮你升级护盾。"

#: src-ru/data/events_zoltan.xml.rawclobber:1187
msgid ""
"data/events_zoltan.xml.rawclobber$//textList[@name=\"START_BEACON_ZOLTON\"]/text[3]"
msgstr ""
