#: src-ru/data/events_zoltan.xml.rawclobber:1089
msgid ""
"data/events_zoltan.xml.rawclobber$//event[@name=\"ZOLTAN_PEACE_QUEST\"]/choice[2]/text"
msgstr "听他们说。"

#: src-ru/data/events_zoltan.xml.rawclobber:1091
msgid ""
"data/events_zoltan.xml.rawclobber$//event[@name=\"ZOLTAN_PEACE_QUEST\"]/choice[2]/event/text"
msgstr "他们继续说：“我们将您的沉默视为感兴趣的表现。”他们开始长篇大论地谈论和平与和谐，但这要么超出了你的理解范围，要么就是彻头彻尾的胡说八道。"

#: src-ru/data/events_zoltan.xml.rawclobber:1095
msgid ""
"data/events_zoltan.xml.rawclobber$//event[@name=\"ZOLTAN_PEACE_QUEST\"]/choice[2]/event/choice/event/text"
msgstr "他们最后说：“请将这些开悟之言传播给那些尚未听闻之人。一旦听闻，请与我们的同胞联系。”他们传给了你他们所谓“同胞”的坐标。"

#: src-ru/data/events_zoltan.xml.rawclobber:1102
msgid ""
"data/events_zoltan.xml.rawclobber$//event[@name=\"ZOLTAN_PEACE_QUEST\"]/choice[3]/text"
