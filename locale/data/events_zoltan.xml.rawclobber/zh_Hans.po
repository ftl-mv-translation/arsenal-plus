#: src-ru/data/events_zoltan.xml.rawclobber:1083
msgid ""
"data/events_zoltan.xml.rawclobber$//event[@name=\"ZOLTAN_PEACE_QUEST\"]/text"
msgstr ""
"一艘手无寸铁的佐尔坦运输船缓缓向信标驶来。他们广播道：“这是佐尔坦和平外交飞船。我们没有武器和护盾，我们完全依靠听众的善意来传播我们的信息。”"

#: src-ru/data/events_zoltan.xml.rawclobber:1085
msgid ""
"data/events_zoltan.xml.rawclobber$//event[@name=\"ZOLTAN_PEACE_QUEST\"]/choice[1]/text"
