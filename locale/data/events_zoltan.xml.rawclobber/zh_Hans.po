#: src-ru/data/events_zoltan.xml.rawclobber:1264
msgid ""
"data/events_zoltan.xml.rawclobber$//textList[@name=\"NEBULA_STORM_ZOLTON_FIGHT\"]/text[3]"
msgstr ""
