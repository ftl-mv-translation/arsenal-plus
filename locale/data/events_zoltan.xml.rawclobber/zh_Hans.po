#: src-ru/data/events_zoltan.xml.rawclobber:1263
msgid ""
"data/events_zoltan.xml.rawclobber$//textList[@name=\"NEBULA_STORM_ZOLTON_FIGHT\"]/text[2]"
msgstr ""
